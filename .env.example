# =========================
# AIGC Checker Engine
# .env 示例配置
# =========================

# ---------------------------------
# 1. 基础运行配置
# ---------------------------------

# 请求默认来源。
# 仅影响请求默认入参，不改变当前固定执行策略：
# - scan 固定走 Ollama
# - reduce 的 rewrite 固定走 Azure -> OpenRouter fallback
API_SOURCE=ollama

# 兼容旧版单 token 逻辑。
# 如果配置了它，这个 token 会按 pro 权限处理。
API_TOKEN=replace_with_legacy_pro_token


# ---------------------------------
# 2. 套餐 token 配置
# ---------------------------------

# 普通版 token，多个用英文逗号分隔。
# 这些 token 只能调用 /api/scan，不支持 /api/reduce，也不会触发远程复核。
FREE_API_TOKENS=free_token_example_1,free_token_example_2

# 会员版 token，多个用英文逗号分隔。
# 这些 token 可以调用 /api/scan 和 /api/reduce，并允许低置信度远程复核。
PRO_API_TOKENS=pro_token_example_1,pro_token_example_2

# 不同套餐最大可检测字符数。
FREE_MAX_CHARS=3000
PRO_MAX_CHARS=12000


# ---------------------------------
# 3. Ollama 配置
# ---------------------------------

# 你的 Ollama 服务地址。
OLLAMA_BASE_URL=http://218.4.33.190:26316

# scan 主检测模型（固定走 Ollama 时使用）。
OLLAMA_MODEL=qwen3.5:9b

# Ollama 请求超时，单位秒。
OLLAMA_TIMEOUT=120

# 是否显式关闭 thinking / reasoning 输出。
# Qwen 等思考模型建议保持 true，避免只返回 thinking 而没有最终 response。
OLLAMA_DISABLE_THINKING=true

# Ollama JSON 判别参数。
OLLAMA_JSON_NUM_CTX=1536
OLLAMA_JSON_NUM_PREDICT=96

# reduce Step2：Ollama 本地 Qwen 扰动参数。
OLLAMA_REWRITE_MODEL=qwen3.5:9b
OLLAMA_REWRITE_NUM_CTX=4096
OLLAMA_REWRITE_NUM_PREDICT=1024


# ---------------------------------
# 4. reduce rewrite 固定提供方链路
# ---------------------------------

# reduce rewrite Step1：Azure GPT-4o 深度语义重写
# 注意：这里传的是 Azure deployment name，不是公共模型 ID。
AZURE_API_KEY=
AZURE_ENDPOINT=
AZURE_DEPLOYMENT=gpt-4o
AZURE_REWRITE_DEPLOYMENT=gpt-4o
AZURE_API_VERSION=2025-01-01-preview

# reduce rewrite Step1 的远端兜底：OpenRouter qwen/qwen-plus
# 注意：这里传的是 OpenRouter model ID。
OPENROUTER_API_KEY=replace_with_openrouter_api_key
OPENROUTER_MODEL=qwen/qwen-plus
OPENROUTER_REWRITE_MODEL=qwen/qwen-plus
OPENROUTER_EXCLUDE_REASONING=true

# self = 直连 OpenRouter
# proxy = 通过内部代理服务转发
OPENROUTER_SEND_MODE=self

# 如果 OPENROUTER_SEND_MODE=proxy，再填写下面两个。
PROXY_BASE_URL=http://119.28.110.115:5000
PROXY_TOKEN=replace_with_proxy_token


# ---------------------------------
# 5. 会员版远程复核配置（可选）
# ---------------------------------

# 会员版在低置信度、边界分数、保守文体时，会尝试远程高级模型复核。
# 可选值：openrouter / azure
PRO_REVIEW_SOURCE=openrouter

# 远程复核模型。
# 如果 PRO_REVIEW_SOURCE=openrouter，这里填 OpenRouter 模型名。
# 如果 PRO_REVIEW_SOURCE=azure，这里填 Azure deployment 名。
PRO_REVIEW_MODEL=qwen/qwen-plus


# ---------------------------------
# 6. Token 生成建议
# ---------------------------------

# 推荐不要手写短 token。
# 可以本地生成高熵随机 token，例如：
#
# openssl rand -hex 24
#
# 会得到类似：
# 9f2a7d6dcb7f0fe4d6f14e63381f5d9c8e6d0a2f0e55d7c1
#
# 你可以一次生成多个，分别放进：
# FREE_API_TOKENS=tokenA,tokenB
# PRO_API_TOKENS=tokenC,tokenD
#
# 调用方使用方式：
# Authorization: Bearer <对应 token>
