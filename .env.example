# API 访问令牌（调用方必须在 Authorization: Bearer <token> 头中携带）
API_TOKEN=your-secret-token-here

# 选择 API 来源: azure（默认）或 openrouter
API_SOURCE=azure

# ── Azure / Microsoft Foundry（API_SOURCE=azure 时必填）────────
AZURE_API_KEY=your-api-key-here
AZURE_ENDPOINT=https://suzhou-gtp4o.cognitiveservices.azure.com/
AZURE_DEPLOYMENT=gpt-4o-mini
AZURE_API_VERSION=2025-01-01-preview

# ── OpenRouter（API_SOURCE=openrouter 时必填）──────────────────
# OPENROUTER_API_KEY=sk-or-v1-...

# OPENROUTER_SEND_MODE	self	self = 直连 OpenRouter；proxy = 走内部代理
OPENROUTER_SEND_MODE=proxy
# 内部代理的 base_url
PROXY_BASE_URL=http://119.28.110.115:5000
# 内部代理的 token
PROXY_TOKEN=10a8ed53-e497-4f59-9662-0c650dd889ff

